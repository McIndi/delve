# Example .env file for Delve Docker Compose
# Copy to .env and fill in values


# Required for security and database access
DELVE_SECRET_KEY=
DELVE_DATABASE_ENGINE=postgresql  # Options: postgresql, mysql, sqlite3
DELVE_DATABASE_NAME=delve
DELVE_DATABASE_USER=delve
DELVE_DATABASE_PASSWORD=
DELVE_DATABASE_HOST=db
DELVE_DATABASE_PORT=5432

# Optional (defaults provided in settings.py)
DELVE_DEBUG=False
DELVE_ALLOWED_HOSTS=web,localhost,127.0.0.1
DELVE_INTERNAL_IPS=127.0.0.1
DELVE_STATIC_URL=/static/
DELVE_STATIC_ROOT=/app/staticfiles
DELVE_LOG_LEVEL=INFO
DELVE_MEDIA_ROOT=/app/uploads/
DELVE_MEDIA_URL=/uploads/
DELVE_SERVER_HOST=0.0.0.0
DELVE_SERVER_PORT=8000
DELVE_Q_CLUSTER_NAME=DjangORM
DELVE_Q_CLUSTER_WORKERS=2
DELVE_Q_CLUSTER_ORM=default
DELVE_DATABASE_NAME=delve
DELVE_DATABASE_HOST=db
DELVE_DATABASE_PORT=5432
# Add other DELVE_* variables as needed
